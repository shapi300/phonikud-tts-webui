# Phonikud TTS WebUI - Gradio Web Interface
FROM python:3.11-slim

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install uv
RUN pip install uv

# Copy project files
COPY pyproject.toml .
COPY ui ./ui

# Install dependencies
RUN uv sync --no-dev

# Expose port
EXPOSE 7860

# Run the UI
CMD ["uv", "run", "python", "ui/app.py"]